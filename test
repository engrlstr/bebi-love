<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>For You 💜</title>

<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap" rel="stylesheet">

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f3e8ff;
    overflow: hidden;
}

/* Hearts */
.heart {
    position: absolute;
    bottom: -20px;
    color: rgba(168, 85, 247, 0.4);
    animation: floatUp 8s linear infinite;
}
@keyframes floatUp {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(-110vh); opacity: 0; }
}

/* Center */
.center {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
}

/* Input */
input {
    padding: 10px;
    border-radius: 10px;
    text-align: center;
}

/* Button */
button {
    padding: 10px 20px;
    background: #a855f7;
    color: white;
    border: none;
    border-radius: 10px;
    margin-top: 10px;
    cursor: pointer;
}
button:hover { background: #9333ea; }

.hidden { display: none; }

/* Welcome */
#welcomeScreen {
    position: absolute;
    width: 100%;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
}
.welcome-text {
    font-family: 'Great Vibes', cursive;
    font-size: 50px;
    color: #6b21a8;
    opacity: 0;
    animation: fade 4s forwards;
}
@keyframes fade {
    0% { opacity: 0; }
    30% { opacity: 1; }
    70% { opacity: 1; }
    100% { opacity: 0; }
}

/* Layout */
#mainPage {
    display: flex;
    height: 100vh;
}

.sidebar {
    width: 200px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: 20px;
}

.content {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
}

/* Sections */
.section { display: none; text-align: center; }

/* Typewriter */
#typewriter {
    border-right: 2px solid purple;
    white-space: pre-wrap;
    overflow: hidden;
}

/* Gallery */
.gallery img {
    width: 150px;
    margin: 10px;
    border-radius: 10px;
    cursor: pointer;
}

/* Lightbox */
#lightbox {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.8);
    display: none;
    justify-content: center;
    align-items: center;
}
#lightbox img {
    max-width: 80%;
    border-radius: 10px;
}
</style>
</head>

<body>

<div id="hearts"></div>

<!-- LOGIN -->
<div class="center" id="loginPage">
    <h2>Enter the secret code</h2>
    <input type="password" id="codeInput" placeholder="****">
    <button onclick="checkCode()">Enter</button>
    <p id="hint"></p>
</div>

<!-- WELCOME -->
<div id="welcomeScreen" class="hidden">
    <div class="welcome-text">Welcome my love! Enjoy po ♥</div>
</div>

<!-- MAIN -->
<div id="mainPage" class="hidden">

    <div class="sidebar">
        <button onclick="showContent('letter')">Love Letter</button>
        <button onclick="showContent('music')">Music</button>
        <button onclick="showContent('notes')">Notes</button>
        <button onclick="showContent('gallery')">Gallery</button>
    </div>

    <div class="content">

        <!-- Love Letter -->
        <div id="letter" class="section">
            <h2>Love Letter 💌</h2>
            <p id="typewriter"></p>
        </div>

        <!-- Music -->
        <div id="music" class="section">
            <h2>Music 🎵</h2>
            <p>I remember you when this song is played 💜</p>
            <audio controls>
                <source src="song.mp3" type="audio/mpeg">
            </audio>
        </div>

        <!-- Notes -->
        <div id="notes" class="section">
            <h2>Notes 📝</h2>
            <p>You are my favorite person always 💜</p>
        </div>

        <!-- Gallery -->
        <div id="gallery" class="section gallery">
            <h2>Gallery 📸</h2>
            <img src="https://picsum.photos/200?1" onclick="openLightbox(this.src)">
            <img src="https://picsum.photos/200?2" onclick="openLightbox(this.src)">
            <img src="https://picsum.photos/200?3" onclick="openLightbox(this.src)">
        </div>

    </div>
</div>

<!-- Lightbox -->
<div id="lightbox" onclick="closeLightbox()">
    <img id="lightboxImg">
</div>

<script>
const SECRET_CODE = "1234";
let attempts = 0;

function checkCode() {
    const input = document.getElementById("codeInput").value;
    attempts++;

    if (input === SECRET_CODE) {
        document.getElementById("loginPage").style.display = "none";
        document.getElementById("welcomeScreen").classList.remove("hidden");

        setTimeout(() => {
            document.getElementById("welcomeScreen").style.display = "none";
            document.getElementById("mainPage").classList.remove("hidden");
        }, 4000);

    } else {
        if (attempts === 2) {
            document.getElementById("hint").innerText = "Hint: our special number 💜";
        } else if (attempts >= 3) {
            document.getElementById("hint").innerText = "Hint: starts with 1...";
        } else {
            alert("Wrong code!");
        }
    }
}

/* Show section */
function showContent(section) {
    document.querySelectorAll(".section").forEach(div => div.style.display = "none");
    document.getElementById(section).style.display = "block";

    if (section === "letter") startTyping();
}

/* Typewriter */
const text = "From the moment I met you, everything felt different. You became my favorite thought, my favorite person, my everything. 💜";
let i = 0;

function startTyping() {
    document.getElementById("typewriter").innerHTML = "";
    i = 0;
    type();
}

function type() {
    if (i < text.length) {
        document.getElementById("typewriter").innerHTML += text.charAt(i);
        i++;
        setTimeout(type, 40);
    }
}

/* Lightbox */
function openLightbox(src) {
    document.getElementById("lightbox").style.display = "flex";
    document.getElementById("lightboxImg").src = src;
}
function closeLightbox() {
    document.getElementById("lightbox").style.display = "none";
}

/* Hearts */
function createHeart() {
    const heart = document.createElement("div");
    heart.classList.add("heart");
    heart.innerHTML = "♥";
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.fontSize = (Math.random() * 20 + 10) + "px";
    document.body.appendChild(heart);
    setTimeout(() => heart.remove(), 8000);
}
setInterval(createHeart, 500);
</script>

</body>
</html>
